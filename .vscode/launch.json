{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API Server (server/index.js)",
      "preLaunchTask": "Free port 5000",
      "program": "${workspaceFolder}/server/index.js",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Run Full App (npm start)",
      "command": "npm start",
      "cwd": "${workspaceFolder}"
    }
  ]
}